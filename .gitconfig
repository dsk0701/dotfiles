[color]
    ui = auto

[user]
    name = dsk0701
    email = d.dubandtribal@gmail.com

[includeIf "gitdir:~/var/mixin/"]
    path = ~/.gitconfig-mixin

[includeIf "gitdir:~/var/dev/"]
    path = ~/.gitconfig-dev

[core]
    excludesfile = ~/.gitignore
    autocrlf = false
    ignorecase = false

[push]
    default = simple

[credential]
    helper = osxkeychain

[pager]
    log = diff-highlight | less
    show = diff-highlight | less
    diff = diff-highlight | less

